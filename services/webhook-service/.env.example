DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=replace-with-a-secure-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,webhook-service
TIME_ZONE=Asia/Ho_Chi_Minh

# Facebook Webhook
FACEBOOK_GRAPH_API_VERSION=v25.0
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-access-token
FACEBOOK_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
FACEBOOK_WEBHOOK_SECRET=your-webhook-signing-secret

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_RAW_EVENTS_TOPIC=raw_events
KAFKA_CLIENT_ID=webhook-service
KAFKA_ACKS=all
KAFKA_PUBLISH_TIMEOUT_SECONDS=5
